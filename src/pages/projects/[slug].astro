---
/**
 * Project Detail Page — Matches George's wireframe
 * 
 * Layout:
 * - Nav top left
 * - Project type tabs: Brand Guide | Collateral (from projectTypes)
 * - Project title
 * - Description paragraph
 * - Images with TEXT OVERLAY ON HOVER (George's request)
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProject, getProjectSlugs, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs = await getProjectSlugs();
  
  if (!slugs || slugs.length === 0) {
    // Demo project for placeholder
    return [
      { params: { slug: 'henry-schein-one' } },
      { params: { slug: 'fluent-dental' } },
      { params: { slug: 'millennia' } },
    ];
  }
  
  return slugs.map(({ slug }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const project = await getProject(slug);

// Demo content if no project found
const displayProject = project || {
  title: 'Henry Schein ONE',
  category: 'brands',
  projectTypes: ['Brand Guide', 'Collateral'],
  description: 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim ad minim veniam, quis nostrud exerci tation ullamcorper suscipit lobortis nisl ut aliquip ex ea commodo consequat.',
  images: [
    { _key: '1', caption: 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat.' },
    { _key: '2', caption: 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit.' },
  ],
};

const projectTypes = displayProject.projectTypes || [];
const categoryLabels = {
  'brands': 'Brands',
  'collateral': 'Collateral',
  'the-rest': 'The Rest',
};
---

<BaseLayout title={`${displayProject.title} — George Rivera`}>
  <section class="project">
    <!-- Project Type Tabs -->
    {projectTypes.length > 0 && (
      <nav class="project__tabs">
        {projectTypes.map((type, i) => (
          <>
            <span class="project__tab">{type}</span>
            {i < projectTypes.length - 1 && <span class="project__separator">|</span>}
          </>
        ))}
      </nav>
    )}
    
    <!-- Project Title -->
    <h1 class="project__title">{displayProject.title}</h1>
    
    <!-- Description -->
    {displayProject.description && (
      <p class="project__description">{displayProject.description}</p>
    )}
    
    <!-- Images with hover text overlay -->
    <div class="project__images">
      {displayProject.images?.length > 0 ? (
        displayProject.images.filter(img => img.asset || img._key).map((image) => {
          const imageUrl = image.asset
            ? urlFor(image).width(1000).format('webp').url()
            : null;
          
          return (
            <figure class="project__image-wrap">
              {imageUrl ? (
                <img src={imageUrl} alt={image.caption || displayProject.title} class="project__image" />
              ) : (
                <div class="project__image-placeholder"></div>
              )}
              {/* Text overlay on hover - George's request */}
              {image.caption && (
                <figcaption class="project__image-caption">
                  {image.caption}
                </figcaption>
              )}
            </figure>
          );
        })
      ) : (
        <>
          <figure class="project__image-wrap">
            <div class="project__image-placeholder"></div>
            <figcaption class="project__image-caption">
              Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt.
            </figcaption>
          </figure>
          <figure class="project__image-wrap">
            <div class="project__image-placeholder"></div>
            <figcaption class="project__image-caption">
              Lorem ipsum dolor sit amet, consectetuer adipiscing elit.
            </figcaption>
          </figure>
        </>
      )}
    </div>
    
    <!-- Back link -->
    <a href={`/category/${displayProject.category || 'brands'}`} class="project__back">
      ← Back to {categoryLabels[displayProject.category] || 'Work'}
    </a>
  </section>
</BaseLayout>
