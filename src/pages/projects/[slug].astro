---
/**
 * Project Detail Page — Matches George's wireframe
 * Layout: Nav, subcategory tabs (project types), title, description, images with hover captions
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProject, getProjectSlugs, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs = await getProjectSlugs();
  
  if (!slugs || slugs.length === 0) {
    return [{ params: { slug: 'placeholder' } }];
  }
  
  return slugs.map(({ slug }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const project = await getProject(slug);

if (!project) {
  return Astro.redirect('/');
}

const categoryLabels = {
  'brands': 'Brands',
  'collateral': 'Collateral',
  'the-rest': 'The Rest',
};

const categoryLabel = categoryLabels[project.category] || project.category;
const projectTypes = project.projectTypes || [];
---

<BaseLayout title={`${project.title} — George Rivera`}>
  <section class="project-page">
    <!-- Project Type Tabs (if any) -->
    {projectTypes.length > 0 && (
      <nav class="project-page__tabs">
        {projectTypes.map((type, i) => (
          <>
            <span class="project-page__tab">{type}</span>
            {i < projectTypes.length - 1 && <span class="project-page__separator">|</span>}
          </>
        ))}
      </nav>
    )}
    
    <!-- Project Title -->
    <h1 class="project-page__title">{project.title}</h1>
    
    <!-- Description -->
    {project.description && (
      <p class="project-page__description">{project.description}</p>
    )}
    
    <!-- Images with hover descriptions -->
    {project.images?.length > 0 && (
      <div class="project-page__images">
        {project.images.filter(img => img.asset).map((image) => {
          const imageUrl = urlFor(image)
            .width(1200)
            .format('webp')
            .url();
          
          return (
            <figure class="project-page__image-wrapper">
              <img 
                src={imageUrl} 
                alt={image.caption || project.title}
                class="project-page__image"
                loading="lazy"
              />
              {image.caption && (
                <figcaption class="project-page__caption">
                  {image.caption}
                </figcaption>
              )}
            </figure>
          );
        })}
      </div>
    )}
    
    <!-- Back link -->
    <a href={`/category/${project.category}`} class="project-page__back">
      ← Back to {categoryLabel}
    </a>
  </section>
</BaseLayout>
