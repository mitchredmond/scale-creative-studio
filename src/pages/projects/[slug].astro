---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProject, getProjectSlugs, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs = await getProjectSlugs();
  
  if (!slugs || slugs.length === 0) {
    return [{ params: { slug: 'placeholder' } }];
  }
  
  return slugs.map(({ slug }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const project = await getProject(slug);

if (!project) {
  return Astro.redirect('/');
}

const categoryLabels = {
  'brands': 'Brands',
  'collateral': 'Collateral',
  'the-rest': 'The Rest',
};

const categoryLabel = categoryLabels[project.category] || project.category;
const year = project.date ? new Date(project.date).getFullYear() : null;
---

<BaseLayout title={`${project.title} — George Rivera`}>
  <div class="project-page">
    <div class="container">
      <header class="project-header">
        <a href={`/category/${project.category}`} class="project-header__back">
          ← Back to {categoryLabel}
        </a>
        
        <h1 class="project-header__title" data-animate>{project.title}</h1>
        
        {project.description && (
          <p class="project-header__description" data-animate>
            {project.description}
          </p>
        )}
        
        <dl class="project-header__meta" data-animate>
          {project.client && (
            <div>
              <dt>Client</dt>
              <dd>{project.client}</dd>
            </div>
          )}
          {project.role && (
            <div>
              <dt>Role</dt>
              <dd>{project.role}</dd>
            </div>
          )}
          {year && (
            <div>
              <dt>Year</dt>
              <dd>{year}</dd>
            </div>
          )}
        </dl>
        
        {project.projectTypes?.length > 0 && (
          <div class="project-header__types">
            {project.projectTypes.map((type) => (
              <span class="project-header__type">{type}</span>
            ))}
          </div>
        )}
      </header>

      {project.images?.length > 0 && (
        <section class="project-images">
          <div class="project-images__grid" data-stagger>
            {project.images.filter(img => img.asset).map((image) => {
              const imageUrl = urlFor(image)
                .width(1600)
                .format('webp')
                .url();
              
              return (
                <figure class:list={[
                  'project-images__item',
                  { 'project-images__item--full': image.fullWidth }
                ]}>
                  <img 
                    src={imageUrl} 
                    alt={image.caption || project.title}
                    loading="lazy"
                  />
                </figure>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>
