---
/**
 * Homepage — Matches George's wireframe exactly
 * Layout: Nav top, tagline center, name below, categories at bottom
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings, getCategoryCounts } from '../lib/sanity';

const settings = await getSettings();
const counts = await getCategoryCounts() || { brands: 0, collateral: 0, theRest: 0 };

const name = settings?.name || 'George Rivera';

const categories = [
  { name: 'Brands', slug: 'brands', count: counts.brands || 0 },
  { name: 'Collateral', slug: 'collateral', count: counts.collateral || 0 },
  { name: 'The Rest', slug: 'the-rest', count: counts.theRest || 0 },
];
---

<BaseLayout>
  <section class="home">
    <h1 class="home__tagline">
      Building, Expanding,<br />and Fulfilling Brands
    </h1>
    
    <p class="home__name">{name}</p>
    
    <nav class="home__categories">
      {categories.map((cat, i) => (
        <>
          <a href={`/category/${cat.slug}`} class="home__category-link">
            {cat.name.toUpperCase()}
          </a>
          {i < categories.length - 1 && <span class="home__separator">|</span>}
        </>
      ))}
    </nav>
  </section>
</BaseLayout>
