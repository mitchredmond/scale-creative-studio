---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings, getCategoryCounts } from '../lib/sanity';

const settings = await getSettings();
const counts = await getCategoryCounts() || { brands: 0, collateral: 0, theRest: 0 };

const name = settings?.name || 'George Rivera';

const categories = [
  { name: 'Brands', slug: 'brands', count: counts.brands || 0 },
  { name: 'Collateral', slug: 'collateral', count: counts.collateral || 0 },
  { name: 'The Rest', slug: 'the-rest', count: counts.theRest || 0 },
];
---

<BaseLayout>
  <section class="hero">
    <p class="hero__name" data-animate>{name}</p>
    <h1 class="hero__tagline" data-animate>
      Building, Expanding,<br />and Fulfilling Brands
    </h1>
    
    <nav class="category-nav" data-stagger>
      {categories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="category-link">
          {cat.name}
          <span class="category-link__count">({cat.count})</span>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
