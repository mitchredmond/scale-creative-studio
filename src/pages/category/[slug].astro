---
/**
 * Category Page — Matches George's wireframe
 * 
 * Layout:
 * - Nav top left
 * - Tagline (smaller)
 * - Category tabs: BRANDS | COLLATERAL | THE REST
 * - Section title (e.g., "Brand Work")
 * - Projects in a row with titles below thumbnails
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectsByCategory, urlFor } from '../../lib/sanity';

export function getStaticPaths() {
  return [
    { params: { slug: 'brands' }, props: { title: 'Brand Work', category: 'brands' } },
    { params: { slug: 'collateral' }, props: { title: 'Collateral', category: 'collateral' } },
    { params: { slug: 'the-rest' }, props: { title: 'The Rest', category: 'the-rest' } },
  ];
}

const { slug } = Astro.params;
const { title, category } = Astro.props;

const projects = await getProjectsByCategory(category) || [];

// Demo projects if none exist
const displayProjects = projects.length > 0 ? projects : [
  { _id: '1', title: 'Henry Schein ONE', slug: { current: 'henry-schein-one' }, thumbnail: null, description: 'Brand identity and guidelines for Henry Schein ONE dental software.' },
  { _id: '2', title: 'Fluent Dental', slug: { current: 'fluent-dental' }, thumbnail: null, description: 'Complete brand system for Fluent Dental practice management.' },
  { _id: '3', title: 'Millennia', slug: { current: 'millennia' }, thumbnail: null, description: 'Visual identity for Millennia healthcare solutions.' },
];

const categories = [
  { name: 'BRANDS', slug: 'brands' },
  { name: 'COLLATERAL', slug: 'collateral' },
  { name: 'THE REST', slug: 'the-rest' },
];
---

<BaseLayout title={`${title} — George Rivera`}>
  <section class="category">
    <!-- Tagline -->
    <h1 class="category__tagline">
      Building, Expanding, and Fulfilling Brands
    </h1>
    
    <!-- Category Tabs -->
    <nav class="category__tabs">
      {categories.map((cat, i) => (
        <>
          <a 
            href={`/category/${cat.slug}`} 
            class:list={['category__tab', { 'is-active': cat.slug === slug }]}
          >
            {cat.name}
          </a>
          {i < categories.length - 1 && <span class="category__separator">|</span>}
        </>
      ))}
    </nav>
    
    <!-- Section Title -->
    <h2 class="category__title">{title}</h2>
    <p class="category__subtitle">One for each Category</p>
    
    <!-- Projects Row -->
    <div class="category__projects">
      {displayProjects.map((project) => {
        const imageUrl = project.thumbnail?.asset
          ? urlFor(project.thumbnail).width(400).height(300).format('webp').url()
          : null;
        
        return (
          <a href={`/projects/${project.slug?.current || project._id}`} class="project-thumb">
            <div class="project-thumb__image-wrap">
              {imageUrl ? (
                <img src={imageUrl} alt={project.title} class="project-thumb__image" />
              ) : (
                <div class="project-thumb__placeholder"></div>
              )}
              <!-- Hover overlay with description -->
              {project.description && (
                <div class="project-thumb__overlay">
                  <p class="project-thumb__description">{project.description}</p>
                </div>
              )}
            </div>
            <h3 class="project-thumb__title">{project.title}</h3>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
