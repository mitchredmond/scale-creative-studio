---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings, urlFor } from '../lib/sanity';

const settings = await getSettings();

const name = settings?.name || 'George Rivera';
const role = settings?.role || 'Creative Director';
const bio = settings?.bio || '';
const email = settings?.email || '';
const socialLinks = settings?.socialLinks || [];

const photoUrl = settings?.photo?.asset
  ? urlFor(settings.photo).width(800).height(1067).format('webp').url()
  : null;
---

<BaseLayout title={`About — ${name}`}>
  <div class="about-page">
    <div class="container">
      <div class="about-content">
        <div class="about-photo" data-animate>
          {photoUrl ? (
            <img src={photoUrl} alt={name} />
          ) : (
            <div style="width: 100%; height: 100%; background: var(--color-bg-alt);"></div>
          )}
        </div>
        
        <div class="about-text">
          <p class="about-text__label" data-animate>{role}</p>
          <h1 class="about-text__name" data-animate>{name}</h1>
          <p class="about-text__bio" data-animate>{bio}</p>
          
          <div class="about-text__links" data-stagger>
            {email && (
              <a href={`mailto:${email}`} class="about-text__link">Email</a>
            )}
            {socialLinks.map((link) => (
              <a 
                href={link.url} 
                class="about-text__link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.platform}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
