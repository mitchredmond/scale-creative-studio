---
/**
 * About Page
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings, urlFor } from '../lib/sanity';

const settings = await getSettings();

const name = settings?.name || 'George Rivera';
const role = settings?.role || 'Creative Director';
const bio = settings?.bio || '';
const email = settings?.email || '';
const socialLinks = settings?.socialLinks || [];

const photoUrl = settings?.photo?.asset
  ? urlFor(settings.photo).width(600).height(750).format('webp').url()
  : null;
---

<BaseLayout title={`About — ${name}`}>
  <section class="about-page">
    <div class="about-page__content">
      <div class="about-page__photo">
        {photoUrl ? (
          <img src={photoUrl} alt={name} />
        ) : (
          <div class="about-page__photo-placeholder"></div>
        )}
      </div>
      
      <div class="about-page__text">
        <p class="about-page__role">{role}</p>
        <h1 class="about-page__name">{name}</h1>
        <p class="about-page__bio">{bio}</p>
        
        <div class="about-page__links">
          {email && (
            <a href={`mailto:${email}`} class="about-page__link">Email</a>
          )}
          {socialLinks.map((link) => (
            <a 
              href={link.url} 
              class="about-page__link"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.platform}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
