---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings, urlFor } from '../lib/sanity';

const settings = await getSettings();

const name = settings?.name || 'George Rivera';
const role = settings?.role || 'Creative Director';
const bio = settings?.bio || 'Award-winning Creative Director with experience in branding, campaigns, and digital experiences.';
const email = settings?.email || '';
const socialLinks = settings?.socialLinks || [];

const photoUrl = settings?.photo?.asset
  ? urlFor(settings.photo).width(500).height(625).format('webp').url()
  : null;
---

<BaseLayout title={`About — ${name}`}>
  <section class="about">
    <div class="about__content">
      <div class="about__photo">
        {photoUrl ? (
          <img src={photoUrl} alt={name} />
        ) : (
          <div class="about__photo-placeholder"></div>
        )}
      </div>
      
      <div class="about__text">
        <p class="about__role">{role}</p>
        <h1 class="about__name">{name}</h1>
        <p class="about__bio">{bio}</p>
        
        <div class="about__links">
          {email && (
            <a href={`mailto:${email}`} class="about__link">Email</a>
          )}
          {socialLinks.map((link) => (
            <a 
              href={link.url} 
              class="about__link"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.platform}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
