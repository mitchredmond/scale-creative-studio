---
/**
 * Project Card — With hover description popup (per George's wireframe note)
 */

import { urlFor } from '../lib/sanity';

interface Props {
  title: string;
  slug: string;
  description?: string;
  thumbnail?: any;
  projectTypes?: string[];
  category: string;
}

const { title, slug, description, thumbnail, projectTypes = [], category } = Astro.props;

const imageUrl = thumbnail?.asset
  ? urlFor(thumbnail).width(600).height(400).format('webp').url()
  : null;
---

<a href={`/projects/${slug}`} class="project-card">
  <div class="project-card__image-container">
    {imageUrl ? (
      <img src={imageUrl} alt={title} class="project-card__image" loading="lazy" />
    ) : (
      <div class="project-card__placeholder"></div>
    )}
    
    <!-- Hover popup with description -->
    {description && (
      <div class="project-card__popup">
        <p class="project-card__popup-text">{description}</p>
      </div>
    )}
  </div>
  
  <h3 class="project-card__title">{title}</h3>
</a>
